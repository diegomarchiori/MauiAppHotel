<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.HospedagemContratada"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">
 
     <VerticalStackLayout VerticalOptions="CenterAndExpand"
                          Padding="20"
                          Spacing="15">
 
         <Label x:Name="lbl_quarto"
                Text="Suíte"
                TextColor="{StaticResource Primary}"
                FontFamily="Kalam"
                FontSize="40"
                HorizontalTextAlignment="Center"
                Margin="0,0,0,10"/>
 
         <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}">
             <StackLayout Orientation="Horizontal">
                 <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                     <Label Text="Adultos: " FontAttributes="Bold" />
                     <Label x:Name="lbl_adultos"
                            Text="0" 
                            TextColor="{StaticResource Primary}" />
                 </HorizontalStackLayout>
 
                 <HorizontalStackLayout HorizontalOptions="CenterAndExpand">
                     <Label Text="Crianças: " FontAttributes="Bold" />
                     <Label x:Name="lbl_criancas"
                            Text="0" 
                            TextColor="{StaticResource Primary}" />
                 </HorizontalStackLayout>
             </StackLayout>
         </Frame>
 
         <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}">
             <Grid ColumnDefinitions="*, *, *"
                   RowDefinitions="Auto, Auto"
                   RowSpacing="5">
                 <Label Grid.Row="0" Grid.Column="0" Text="Check-in" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                 <Label Grid.Row="0" Grid.Column="1" Text="Check-out" FontAttributes="Bold" HorizontalTextAlignment="Center" />
                 <Label Grid.Row="0" Grid.Column="2" Text="Estadia" FontAttributes="Bold" HorizontalTextAlignment="Center" />
 
                 <Label Grid.Row="1" Grid.Column="0" x:Name="lbl_checkin" Text="00/00/0000" HorizontalTextAlignment="Center" />
                 <Label Grid.Row="1" Grid.Column="1" x:Name="lbl_checkout" Text="00/00/0000" HorizontalTextAlignment="Center" />
                 <Label Grid.Row="1" Grid.Column="2" x:Name="lbl_estadia" Text="0 dias" HorizontalTextAlignment="Center" />
             </Grid>
         </Frame>
 
         <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}" BackgroundColor="#F8F9FA">
             <HorizontalStackLayout HorizontalOptions="CenterAndExpand" Spacing="5">
                 <Label Text="Valor Total:" FontAttributes="Bold" FontSize="Large" VerticalOptions="Center"/>
                 <Label x:Name="lbl_valor_total" Text="R$ 0,00" TextColor="{StaticResource Primary}" FontAttributes="Bold" FontSize="Large" VerticalOptions="Center"/>
             </HorizontalStackLayout>
         </Frame>
 
         <VerticalStackLayout Spacing="10" Margin="0,15,0,0">
             <Button Text="Confirmar Reserva"
                     Clicked="BtnConfirmar_Clicked"
                     CornerRadius="25"
                     HeightRequest="50"
                     FontSize="16"
                     FontAttributes="Bold"
                     BackgroundColor="{StaticResource Primary}"
                     TextColor="White"/>
                     
             <Button Text="Voltar"
                     Clicked="BtnVoltar_Clicked"
                     CornerRadius="25"
                     HeightRequest="50"
                     FontSize="16"
                     BackgroundColor="Transparent"
                     TextColor="{StaticResource Primary}"
                     BorderColor="{StaticResource Primary}"
                     BorderWidth="2"/>
         </VerticalStackLayout>
 
     </VerticalStackLayout>
</ContentPage>