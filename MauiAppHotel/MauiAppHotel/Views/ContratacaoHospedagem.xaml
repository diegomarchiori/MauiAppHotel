<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ContratacaoHospedagem"
             Title="ContratacaoHospedagem"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand"
                         Padding="20"
                         Spacing="15">
 
         <Label Text="Cálculo da Diária"
                FontFamily="Kalam"
                FontSize="40"
                TextColor="{StaticResource Primary}"
                HorizontalTextAlignment="Center"
                Margin="0,0,0,10" />
 
         <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}">
             <VerticalStackLayout Spacing="15">
                 <Grid RowDefinitions="Auto, Auto"
                       ColumnDefinitions="*, *, 2*"
                       RowSpacing="15"
                       VerticalOptions="Center">
 
                     <Label Grid.Row="0" Grid.Column="0"
                            Text="Adultos:" 
                            FontAttributes="Bold"
                            VerticalOptions="Center" />
 
                     <Label Grid.Row="0" Grid.Column="1"
                            TextColor="{StaticResource Primary}"
                            Text="{Binding Value}"
                            FontAttributes="Bold"
                            FontSize="Medium"
                            BindingContext="{x:Reference stp_adultos}"
                            VerticalOptions="Center" />
 
                     <Stepper Grid.Row="0" Grid.Column="2"
                              x:Name="stp_adultos"
                              Minimum="0"
                              Maximum="10"
                              Increment="1"
                              HorizontalOptions="End"
                              VerticalOptions="Center" />
 
                     <Label Grid.Row="1" Grid.Column="0"
                            Text="Crianças:" 
                            FontAttributes="Bold"
                            VerticalOptions="Center" />
 
                     <Label Grid.Row="1" Grid.Column="1"
                            TextColor="{StaticResource Primary}"
                            Text="{Binding Value}"
                            FontAttributes="Bold"
                            FontSize="Medium"
                            BindingContext="{x:Reference stp_criancas}"
                            VerticalOptions="Center" />
 
                     <Stepper Grid.Row="1" Grid.Column="2"
                              x:Name="stp_criancas"
                              Minimum="0"
                              Maximum="10"
                              Increment="1"
                              HorizontalOptions="End"
                              VerticalOptions="Center" />
                 </Grid>
 
                 <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}" BackgroundColor="#F8F9FA">
                     <VerticalStackLayout Spacing="5">
                         <Label Text="Escolha sua Suíte"
                                TextTransform="Uppercase"
                                FontSize="Subtitle"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"/>
 
                         <Picker x:Name="pck_quarto"
                                 Title="Selecione sua Acomodação"
                                 ItemDisplayBinding="{Binding Descricao}"/>
                     </VerticalStackLayout>
                 </Frame>
 
                 <Frame CornerRadius="10" Padding="15" BorderColor="{StaticResource Gray200}" BackgroundColor="#F8F9FA">
                     <VerticalStackLayout Spacing="10">
                         <Label Text="Período da Estadia"
                                TextTransform="Uppercase"
                                FontSize="Subtitle"
                                FontAttributes="Bold"
                                TextColor="{StaticResource Primary}"/>
 
                         <Grid ColumnDefinitions="*, *" RowSpacing="10" ColumnSpacing="10">
                             <VerticalStackLayout Grid.Column="0" Spacing="2">
                                 <Label Text="Check-in:" FontAttributes="Bold" FontSize="Caption" TextColor="{StaticResource Gray500}"/>
                                 <DatePicker x:Name="dtpck_checkin"
                                             DateSelected="dtpck_checkin_DateSelected"
                                             Format="dd/MM/yyyy" />
                             </VerticalStackLayout>
 
                             <VerticalStackLayout Grid.Column="1" Spacing="2">
                                 <Label Text="Check-out:" FontAttributes="Bold" FontSize="Caption" TextColor="{StaticResource Gray500}"/>
                                 <DatePicker x:Name="dtpck_checkout"
                                             Format="dd/MM/yyyy" />
                             </VerticalStackLayout>
                         </Grid>
                     </VerticalStackLayout>
                 </Frame>
 
                 <Button Text="Avançar" 
                         Clicked="Button_Clicked"
                         CornerRadius="25"
                         HeightRequest="50"
                         FontSize="16"
                         FontAttributes="Bold"
                         BackgroundColor="{StaticResource Primary}"
                         TextColor="White"
                         Margin="0,10,0,0" />
 
             </VerticalStackLayout>
         </Frame>
 
     </VerticalStackLayout>
</ContentPage>