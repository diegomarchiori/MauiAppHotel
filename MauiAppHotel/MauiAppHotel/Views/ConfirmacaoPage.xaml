<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppHotel.Views.ConfirmacaoPage"
             NavigationPage.HasNavigationBar="False"
             BackgroundColor="{StaticResource Gray100}">

    <VerticalStackLayout VerticalOptions="CenterAndExpand"
                         Padding="30"
                         Spacing="25"
                         HorizontalOptions="Center">

        <!-- Círculo de Sucesso Verde/Teal com Checkmark -->
        <Border StrokeShape="RoundRectangle 50"
                Stroke="{StaticResource Primary}"
                StrokeThickness="3"
                BackgroundColor="White"
                WidthRequest="100"
                HeightRequest="100"
                HorizontalOptions="Center"
                Padding="0">
            <Label Text="✓"
                   TextColor="{StaticResource Primary}"
                   FontSize="50"
                   FontAttributes="Bold"
                   HorizontalOptions="Center"
                   VerticalOptions="Center" />
        </Border>

        <Label Text="Transação Realizada!"
               FontFamily="Kalam"
               FontSize="36"
               TextColor="{StaticResource Primary}"
               HorizontalTextAlignment="Center" />

        <Label Text="Sua reserva de hospedagem foi confirmada com sucesso. Esperamos por você!"
               FontSize="16"
               TextColor="{StaticResource Gray500}"
               HorizontalTextAlignment="Center"
               Margin="0,0,0,20" />

        <Button Text="Voltar ao Início"
                Clicked="BtnVoltarInicio_Clicked"
                CornerRadius="25"
                HeightRequest="50"
                WidthRequest="220"
                FontSize="16"
                FontAttributes="Bold"
                BackgroundColor="{StaticResource Primary}"
                TextColor="White"
                HorizontalOptions="Center" />

    </VerticalStackLayout>
</ContentPage>
